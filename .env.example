# ============================================================
# YouTube Topic RAG -- Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# --- PostgreSQL (Neon serverless) ---
# Get from: console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# --- OpenAI ---
# Used for: embeddings (text-embedding-3-small) + RAG synthesis (gpt-4o-mini)
OPENAI_API_KEY=sk-...

# --- Anthropic ---
# Used for: chapter generation + per-video topic classification (claude-haiku-4-5-20251001)
ANTHROPIC_API_KEY=sk-ant-...

# --- Pinecone ---
# Index must be: dotproduct metric, 1536 dims, Serverless / AWS us-east-1
# Get from: app.pinecone.io → API Keys
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=youtube-rag-index

# --- YouTube Data API v3 ---
# Get from: console.cloud.google.com → APIs & Services → Credentials
YOUTUBE_API_KEY=AIza...

# --- AWS (Lambda uses IAM role in prod; these are for local dev only) ---
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1

# --- SQS Queue URLs (used by dashboard for queue depth monitoring) ---
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/youtube-video-process-queue
SQS_DLQ_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/youtube-video-process-dlq

# --- S3 ---
S3_BUCKET_NAME=startup-thematic-transcripts-production

# --- Local dev overrides ---
# Set S3_LOCAL_PATH to save transcript JSON to disk instead of uploading to S3.
# Remove or leave blank to use real S3.
S3_LOCAL_PATH=./local_data

# Directory where sentence-transformers caches the cross-encoder model.
# Set to /tmp when deploying to Lambda.
SENTENCE_TRANSFORMERS_HOME=./local_data/models
